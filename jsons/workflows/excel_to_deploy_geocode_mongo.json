{
  "stop_on_error": true,
  "steps": [
    {
      "id": "convert",
      "module": "plugins.system_tools.excel_plugin",
      "class": "ExcelPlugin",
      "method": "excel_to_json",
      "constructor_args": {
        "base_dir": "generated_data",
        "allow_outside_base_dir": true
      },
      "args": [
        {
          "file_path": "C:/Users/Paul/Documents/Projects/paramiko/temp.xlsm",
          "sheet": "r1",
          "save_as": "C:/Users/Paul/Documents/Projects/paramiko/temp_r1.json",
          "sanitize_keys": true,
          "include_row_index": false,
          "write_file": true
        }
      ]
    },
    {
      "id": "active",
      "module": "plugins.system_tools.file_reader_plugin",
      "class": "FileReaderPlugin",
      "method": "filter_json_records",
      "constructor_args": {
        "base_dir": "generated_data",
        "allow_outside_base_dir": true
      },
      "args": [
        {
          "file_path": "${steps.convert.result.save_as}",
          "where": { "activate": "x" },
          "name_template": "{Site} ({Loc Code})"
        }
      ]
    },
    {
      "id": "deploy",
      "module": "plugins.system_tools.file_system_plugin",
      "class": "FileSystemPlugin",
      "method": "deploy_template_to_projects",
      "constructor_args": {
        "base_dir": "generated_data",
        "allow_outside_base_dir": true
      },
      "args": [
        {
          "template_dir": "C:/Users/Paul/OneDrive - Los Angeles Unified School District/Paul's Share Folder/Project Sites/_Template",
          "projects_root": "generated_data/Project Sites",
          "project_names": "${steps.active.result.names}",
          "copy_files": true,
          "ignore_dirs": [".venv", "__pycache__", ".git"],
          "overwrite": false,
          "stop_on_error": false
        }
      ]
    },
    {
      "id": "geocode",
      "module": "plugins.integrations.geocoding_plugin",
      "class": "NominatimGeocodingPlugin",
      "method": "bulk_geocode_records",
      "constructor_args": {
        "user_agent": "dynamic-exec-service-geocoder/1.0 (paglipay@gmail.com)"
      },
      "args": [
        {
          "records": "${steps.active.result.records}",
          "school_field": "School Name",
          "address_field": "Address",
          "city_field": "City",
          "out_lat_field": "latitude",
          "out_lon_field": "longitude",
          "out_full_address_field": "geo_address",
          "out_parsed_address_field": "Address",
          "out_timestamp_field": "geocoded_at",
          "rate_limit_seconds": 1.1,
          "skip_if_lat_set": false,
          "timeout_seconds": 10,
          "max_retries": 3
        }
      ]
    },
    {
      "id": "upsert",
      "module": "plugins.mongodb_plugin",
      "class": "MongoDBPlugin",
      "method": "bulk_upsert_documents",
      "constructor_args": {
        "database": "dynamic-exec-service-streamlit"
      },
      "args": [
        {
          "collection": "r1_data",
          "documents": "${steps.geocode.result.records}",
          "key_field": "Loc Code",
          "timestamp_field": "_last_synced",
          "set_extra": { "_source": "temp_r1.json" },
          "ordered": false,
          "dry_run": false,
          "sample_size": 5
        }
      ]
    }
  ]
}
