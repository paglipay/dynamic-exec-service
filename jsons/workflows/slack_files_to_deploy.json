{
  "stop_on_error": true,
  "steps": [
    {
      "id": "get_schools",
      "module": "plugins.mongodb_plugin",
      "class": "MongoDBPlugin",
      "method": "find_documents",
      "constructor_args": {
        "database": "dynamic-exec-service-streamlit"
      },
      "args": [
        "r1_data",
        { "latitude": { "$exists": true }, "longitude": { "$exists": true } },
        ["Site", "Loc Code", "School Name", "Address", "latitude", "longitude"],
        null,
        200
      ]
    },
    {
      "id": "get_images",
      "module": "plugins.mongodb_plugin",
      "class": "MongoDBPlugin",
      "method": "find_documents",
      "constructor_args": {
        "database": "dynamic-exec-service-streamlit"
      },
      "args": [
        "slack_files",
        {},
        ["filename", "name", "title", "gps", "latitude", "longitude", "lat", "lon",
         "location", "download_status", "url_private", "url_private_download", "exif_b64"],
        null,
        200
      ]
    },
    {
      "id": "restore",
      "module": "plugins.system_tools.slack_image_restore_plugin",
      "class": "SlackImageRestorePlugin",
      "method": "restore_and_place",
      "constructor_args": {
        "projects_root": "C:/Users/Paul/OneDrive - Los Angeles Unified School District/Paul's Share Folder/Project Sites",
        "image_subfolder": "Camera/Design/Pictures",
        "max_distance_km": 2.0,
        "site_field": "Site",
        "loc_code_field": "Loc Code",
        "update_mongo": true
      },
      "args": [
        "${steps.get_schools.result.documents}",
        "${steps.get_images.result.documents}",
        false,
        false
      ]
    },
    {
      "id": "deploy",
      "module": "plugins.system_tools.file_system_plugin",
      "class": "FileSystemPlugin",
      "method": "deploy_template_to_projects",
      "constructor_args": {
        "base_dir": "generated_data",
        "allow_outside_base_dir": true
      },
      "args": [
        {
          "template_dir": "C:/Users/Paul/OneDrive - Los Angeles Unified School District/Paul's Share Folder/Project Sites/_Template",
          "projects_root": "C:/Users/Paul/OneDrive - Los Angeles Unified School District/Paul's Share Folder/Project Sites",
          "project_names": "${steps.restore.result.project_names}",
          "copy_files": true,
          "ignore_dirs": [".venv", "__pycache__", ".git"],
          "overwrite": false,
          "stop_on_error": false
        }
      ]
    }
  ]
}

