{
  "stop_on_error": true,
  "steps": [
    {
      "id": "read_notes",
      "module": "plugins.text_file_crud_plugin",
      "class": "TextFileCRUDPlugin",
      "method": "read_text",
      "constructor_args": {
        "base_dir": "generated_data"
      },
      "args": ["notes.txt"]
    },
    {
      "id": "openai_notes_reply",
      "module": "plugins.integrations.openai_sdk_plugin",
      "class": "OpenAISDKPlugin",
      "method": "generate_text_with_history",
      "constructor_args": {},
      "args": [
        "readme-reply-thread",
        "Summarize these notes and suggest next actions:\n\n${steps.read_notes.result.content}",
        "gpt-4.1-mini",
        true
      ]
    }
  ]
}
