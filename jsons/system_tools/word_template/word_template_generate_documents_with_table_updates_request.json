{
  "module": "plugins.system_tools.word_template_plugin",
  "class": "WordTemplatePlugin",
  "method": "generate_documents",
  "constructor_args": {
    "base_dir": ".",
    "allow_outside_base_dir": true
  },
  "args": [
    {
      "schools_json": [
        {
          "LOCATION_CODE": 7574,
          "SCHOOL_NAME": "Horace Mann UCLA Community School",
          "ADDRESS": "7001 S ST ANDREWS PL",
          "CITY": "LOS ANGELES, CA",
          "VENDOR": "CSIB",
          "ENGINEER": "Paul Aglipay"
        }
      ],
      "templates_json": [
        {
          "INPUT_DOCX": "C:/Users/Paul/OneDrive - Los Angeles Unified School District/Paul's Share Folder/Templates/Paul/Template - CCTV Punch List (Test).docx",
          "OUTPUT_DIR": "C:/Users/Paul/OneDrive - Los Angeles Unified School District/Paul's Share Folder",
          "filename": "CCTV/Punch List - CCTV {school_name_sanitized} (Contractor).docx"
        }
      ],
      "replacements_json": [
        {
          "find": "<SCHOOL_NAME>",
          "replace": "<SCHOOL_NAME>"
        },
        {
          "find": "<LOCATION_CODE>",
          "replace": "<LOCATION_CODE>"
        },
        {
          "find": "<ADDRESS>",
          "replace": "<ADDRESS>"
        },
        {
          "find": "<DATE>",
          "replace": "03/11/2026"
        },
        {
          "find": "<VENDOR>",
          "replace": "<VENDOR>"
        },
        {
          "find": "<ENGINEER>",
          "replace": "Paul Aglipay"
        }
      ],
      "table_updates": [
        {
          "table_selector": {
            "header_contains": ["Item No.", "Location"]
          },
          "template_row_marker": "<ROW_TEMPLATE>",
          "remove_template_row": true,
          "rows": [
            {
              "ITEM_NO": "1",
              "LOCATION": "<LOCATION>",
              "SOW": "SOW",
              "DESCRIPTION_OF_CORRECTIVE_ITEM": "<DESCRIPTION_OF_CORRECTIVE_ITEM>",
              "CONTRACTOR": "Contractor",
              "CORRECTED": "<CORRECTED>"
            },
            {
              "ITEM_NO": "2",
              "LOCATION": "<LOCATION>",
              "SOW": "SOW",
              "DESCRIPTION_OF_CORRECTIVE_ITEM": "<DESCRIPTION_OF_CORRECTIVE_ITEM>",
              "CONTRACTOR": "Contractor",
              "CORRECTED": "<CORRECTED>"
            }
          ]
        }
      ],
      "append_lines": ["Generated by WordTemplatePlugin"],
      "export_pdf": true,
      "active_flag_field": "activate",
      "active_flag_value": "x"
    }
  ]
}
