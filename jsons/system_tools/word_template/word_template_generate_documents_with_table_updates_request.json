{
  "module": "plugins.system_tools.word_template_plugin",
  "class": "WordTemplatePlugin",
  "method": "generate_documents",
  "constructor_args": {
    "base_dir": ".",
    "allow_outside_base_dir": true
  },
  "args": [
    {
      "rows": [
        {
          "Document Id": "INV-1001",
          "Customer": "Acme Corp",
          "Account Manager": "Pat Lee"
        }
      ],
      "input_docx": "generated_data/templates/invoice_template.docx",
      "output_dir": "generated_data/output/word_template",
      "filename_template": "Invoice_{Document Id_sanitized}.docx",
      "table_updates": [
        {
          "table_selector": {
            "header_contains": [
              "Item",
              "Qty",
              "Price"
            ]
          },
          "template_row_marker": "<ROW_TEMPLATE>",
          "remove_template_row": true,
          "rows": [
            {
              "Item": "Switch 24-port",
              "Qty": "2",
              "Price": "$420"
            },
            {
              "Item": "Patch Panel",
              "Qty": "4",
              "Price": "$95"
            }
          ]
        }
      ],
      "append_lines": [
        "Thank you for your business."
      ],
      "export_pdf": true
    }
  ]
}
