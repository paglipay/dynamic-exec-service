{
  "module": "plugins.system_tools.word_template_plugin",
  "class": "WordTemplatePlugin",
  "method": "generate_documents",
  "constructor_args": {
    "base_dir": ".",
    "allow_outside_base_dir": true
  },
  "args": [
    {
      "schools_json": [
        {
          "LOCATION_CODE": 7574,
          "SCHOOL_NAME": "Horace Mann UCLA Community School",
          "ADDRESS": "7001 S ST ANDREWS PL",
          "CITY": "LOS ANGELES, CA",
          "VENDOR": "CSIB",
          "ENGINEER": "Paul Aglipay"
        }
      ],
      "templates_json": [
        {
          "INPUT_DOCX": "C:/Users/Paul/OneDrive - Los Angeles Unified School District/Paul's Share Folder/Templates/Paul/Template - CCTV Punch List (Test).docx",
          "OUTPUT_DIR": "C:/Users/Paul/OneDrive - Los Angeles Unified School District/Paul's Share Folder",
          "filename": "CCTV/Punch List - CCTV {school_name_sanitized} (Contractor).docx"
        },
        {
          "INPUT_DOCX": "C:/Users/Paul/OneDrive - Los Angeles Unified School District/Paul's Share Folder/Templates/Paul/Template - IA Punch List (Test).docx",
          "OUTPUT_DIR": "C:/Users/Paul/OneDrive - Los Angeles Unified School District/Paul's Share Folder",
          "filename": "IA/Punch List - IA {school_name_sanitized} (Contractor).docx"
        }
      ],
      "replacements_json": [
        {
          "replace": "Van Nuys Elementary School",
          "find": "<SCHOOL_NAME>"
        },
        {
          "replace": "7438",
          "find": "<LOCATION_CODE>"
        },
        {
          "replace": "TBD",
          "find": "<ADDRESS>"
        },
        {
          "replace": "03/11/2026",
          "find": "<DATE>"
        },
        {
          "replace": "NTT/RMS",
          "find": "<VENDOR>"
        },
        {
          "replace": "Converge One (C1)",
          "find": "<WARRANTY_PROVIDER>"
        },
        {
          "replace": "Paul Aglipay",
          "find": "<ENGINEER>"
        }
      ],
      "append_lines": ["Generated by WordTemplatePlugin"],
      "export_pdf": true,
      "active_flag_field": "activate",
      "active_flag_value": "x"
    }
  ]
}
