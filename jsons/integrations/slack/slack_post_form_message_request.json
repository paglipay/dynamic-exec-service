{
  "module": "plugins.integrations.slack_plugin",
  "class": "SlackPlugin",
  "method": "post_form_message",
  "constructor_args": {
    "default_channel": "#general"
  },
  "args": [
    {
      "channel": "#general",
      "text": "Please complete this form.",
      "blocks": [
        {
          "type": "section",
          "text": {
            "type": "mrkdwn",
            "text": "*Sample Form*"
          }
        },
        {
          "type": "input",
          "block_id": "name_block",
          "label": {
            "type": "plain_text",
            "text": "Your Name"
          },
          "element": {
            "type": "plain_text_input",
            "action_id": "user_name",
            "placeholder": {
              "type": "plain_text",
              "text": "Enter your name"
            }
          }
        },
        {
          "type": "input",
          "block_id": "choice_block",
          "label": {
            "type": "plain_text",
            "text": "Choose an option"
          },
          "element": {
            "type": "static_select",
            "action_id": "user_choice",
            "placeholder": {
              "type": "plain_text",
              "text": "Select one"
            },
            "options": [
              {
                "text": { "type": "plain_text", "text": "Option 1" },
                "value": "option1"
              },
              {
                "text": { "type": "plain_text", "text": "Option 2" },
                "value": "option2"
              }
            ]
          }
        },
        {
          "type": "actions",
          "elements": [
            {
              "type": "button",
              "text": { "type": "plain_text", "text": "Submit" },
              "style": "primary",
              "action_id": "submit_form",
              "value": "submit_form"
            }
          ]
        }
      ]
    }
  ]
}
