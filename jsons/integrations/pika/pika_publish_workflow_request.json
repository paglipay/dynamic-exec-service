{
  "module": "plugins.integrations.pika_plugin",
  "class": "PikaPlugin",
  "method": "publish_workflow",
  "constructor_args": {
    "host": "localhost",
    "port": 5672,
    "virtual_host": "/",
    "username": "guest",
    "password": "guest"
  },
  "args": [
    {
      "queue_name": "workflow_queue",
      "workflow_id": "wf-sample-001",
      "max_retries": 2,
      "meta": {
        "source": "manual-test",
        "purpose": "pika workflow queue MVP"
      },
      "workflow": {
        "stop_on_error": true,
        "steps": [
          {
            "id": "read_readme",
            "module": "plugins.text_file_crud_plugin",
            "class": "TextFileCRUDPlugin",
            "method": "read_text",
            "constructor_args": {
              "base_dir": "generated_data"
            },
            "args": ["README.md"]
          },
          {
            "id": "openai_reply",
            "module": "plugins.integrations.openai_sdk_plugin",
            "class": "OpenAISDKPlugin",
            "method": "generate_text_with_history",
            "constructor_args": {},
            "args": [
              "readme-reply-thread",
              "${steps.read_readme.result.content}",
              "gpt-4.1-mini",
              true
            ]
          },
          {
            "id": "openai_followup",
            "module": "plugins.integrations.openai_sdk_plugin",
            "class": "OpenAISDKPlugin",
            "method": "generate_text_with_history",
            "constructor_args": {},
            "args": [
              "readme-reply-thread",
              "What were we talking about?",
              "gpt-4.1-mini",
              true
            ]
          }
        ]
      },
      "durable": true,
      "persistent": true
    }
  ]
}
