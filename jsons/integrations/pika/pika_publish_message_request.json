{
  "module": "plugins.integrations.pika_plugin",
  "class": "PikaPlugin",
  "method": "publish_message",
  "constructor_args": {
    "host": "localhost",
    "port": 5672,
    "virtual_host": "/",
    "username": "guest",
    "password": "guest"
  },
  "args": [
    {
      "queue_name": "demo_queue",
      "message": {
        "stop_on_error": true,
        "steps": [
          {
            "id": "sum",
            "module": "plugins.sample_module",
            "class": "SampleModule",
            "method": "add",
            "constructor_args": {
              "name": "demo",
              "data": "seed"
            },
            "args": [5, 7]
          },
          {
            "id": "multiply",
            "module": "plugins.generated_math_plugin",
            "class": "GeneratedMathPlugin",
            "method": "multiply",
            "constructor_args": {},
            "args": ["${steps.sum.result}", 3]
          }
        ]
      },
      "durable": true,
      "persistent": true
    }
  ]
}
