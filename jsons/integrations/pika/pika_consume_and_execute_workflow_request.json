{
  "module": "plugins.integrations.pika_plugin",
  "class": "PikaPlugin",
  "method": "consume_and_execute_workflow",
  "constructor_args": {
    "host": "localhost",
    "port": 5672,
    "virtual_host": "/",
    "username": "guest",
    "password": "guest"
  },
  "args": [
    {
      "queue_name": "workflow_queue",
      "timeout_seconds": 8.0,
      "poll_interval_seconds": 0.2,
      "declare_queue": true,
      "durable": true,
      "max_retries": 2,
      "dead_letter_queue": "workflow_queue_dlq"
    }
  ]
}
