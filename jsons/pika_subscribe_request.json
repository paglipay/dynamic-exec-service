{
  "module": "plugins.integrations.pika_plugin",
  "class": "PikaPlugin",
  "method": "subscribe",
  "constructor_args": {
    "host": "localhost",
    "port": 5672,
    "virtual_host": "/",
    "username": "guest",
    "password": "guest"
  },
